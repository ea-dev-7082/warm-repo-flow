create table public.ordens_producao (
  numero_ordem integer not null,
  data_ordem date not null,
  data_emissao timestamp without time zone not null,
  id_analise integer null,
  empresa character varying(200) null,
  cliente character varying(100) null,
  usuario character varying(50) null,
  constraint ordens_producao_pkey primary key (numero_ordem)
) TABLESPACE pg_default;